@{
    ViewBag.Title = "Save Marks";
}

<style>
    body {
        background: #f4f6f9;
        font-family: Arial;
    }

    .marks-container {
        max-width: 700px;
        margin: 40px auto;
        background: white;
        padding: 30px;
        border-radius: 12px;
        box-shadow: 0 4px 12px rgba(0,0,0,.1);
    }

    .page-title {
        text-align: center;
        color: #224abe;
        margin-bottom: 25px;
    }

    .student-box {
        background: #f8f9fa;
        padding: 15px;
        border-radius: 8px;
        margin-bottom: 20px;
    }

    .form-group {
        margin-bottom: 15px;
    }

    label {
        font-weight: bold;
        display: block;
        margin-bottom: 5px;
    }

    .form-control {
        width: 100%;
        padding: 10px;
        border: 1px solid #ddd;
        border-radius: 6px;
        box-sizing: border-box;
    }

    .btn-save {
        background: #28a745;
        color: white;
        border: none;
        padding: 10px 18px;
        border-radius: 6px;
        cursor: pointer;
    }

    .btn-back {
        background: #6c757d;
        color: white;
        text-decoration: none;
        padding: 10px 18px;
        border-radius: 6px;
        margin-left: 10px;
    }
</style>

<div class="marks-container">

    <h2 class="page-title">
        Enter Marks
    </h2>

    <div class="student-box">

        <p>
            <strong>Student Id:</strong>
            @ViewBag.Student.StudentId
        </p>

        <p>
            <strong>Student Name:</strong>
            @ViewBag.Student.StudentName
        </p>

        <p>
            <strong>Class:</strong>
            @ViewBag.Student.StudentClass
        </p>

    </div>

    @using (Html.BeginForm("SaveMarks", "Exam", FormMethod.Post))
    {
        <input type="hidden"
               name="examId"
               value="@ViewBag.ExamId" />

        <input type="hidden"
               name="studentId"
               value="@ViewBag.StudentId" />

        <div class="form-group">
            <label>Subject</label>

                <select name="subject" class="form-control" required>
                    <option value="">-- Select Subject --</option>
                    <option value="English">English</option>
                    <option value="Hindi">Hindi</option>
                    <option value="Science">Science</option>
                    <option value="Math">Math</option>
                    <option value="Social Science">Social Science</option>
                </select>
            </div>

        <div class="form-group">
            <label>Marks Obtained</label>

            <input type="number"
                   name="marksObtained"
                   class="form-control"
                   required />
        </div>

        <div class="form-group">
            <label>Maximum Marks</label>

            <input type="number"
                   name="maxMarks"
                   class="form-control"
                   value="100"
                   required />
        </div>

        <button type="submit"
                class="btn-save">

            Save Marks

        </button>

        <a href="@Url.Action(
                    "AddMarks",
                    "Exam",
                    new { id = ViewBag.ExamId })"
           class="btn-back">
            Back
        </a>
    }
</div>