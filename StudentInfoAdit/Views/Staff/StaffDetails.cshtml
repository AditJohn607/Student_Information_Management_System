@model List<StudentInfoAdit.Models.StaffModel>
@{
    ViewBag.Title = "Staff Details";
}
<style>
    body {
        margin: 0;
        padding: 0;
        font-family: 'Comic Sans MS', 'Segoe UI', sans-serif;
        background: linear-gradient(135deg, #89f7fe, #66a6ff);
        min-height: 100vh;
    }

    .form-container {
        width: 95%;
        max-width: 1100px;
        margin: 40px auto;
        background: white;
        padding: 30px;
        border-radius: 25px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.15);
        border: 5px dashed #ffd54f;
    }

    h2 {
        text-align: center;
        font-size: 38px;
        color: #ff4081;
        margin-bottom: 25px;
        text-shadow: 2px 2px #fff176;
    }

    p {
        text-align: center;
        margin-bottom: 25px;
    }

    .btn {
        padding: 12px 20px; 
        border-radius: 12px;
        text-decoration: none;
        color: white;
        font-size: 17px;
        font-weight: bold;
        margin: 5px;
        display: inline-block;
        transition: 0.3s;
    }

        .btn:hover {
            transform: scale(1.08);
        }

    .btn-success {
        background: #4caf50;
    }

        .btn-success:hover {
            background: #43a047;
        }

    .btn-info {
        background: #29b6f6;
    }

        .btn-info:hover {
            background: #039be5;
        }

    .btn-primary {
        background: #7e57c2;
        padding: 8px 14px;
        font-size: 14px;
    }

        .btn-primary:hover {
            background: #5e35b1;
        }

    .btn-danger {
        background: #ef5350;
        padding: 8px 14px;
        font-size: 14px;
    }

        .btn-danger:hover {
            background: #e53935;
        }

    .student-table {
        width: 100%;
        border-collapse: collapse;
        overflow: hidden;
        border-radius: 15px;
    }

        .student-table th {
            background: linear-gradient(90deg, #ff9a9e, #fad0c4);
            color: #333;
            padding: 15px;
            font-size: 18px;
        }

        .student-table td {
            padding: 14px;
            text-align: center;
            font-size: 16px;
            border-bottom: 2px solid #f1f1f1;
        }

        .student-table tr:nth-child(even) {
            background: #f9f9ff;
        }

        .student-table tr:nth-child(odd) {
            background: #ffffff; 
        }

        .student-table tr:hover {
            background: #fff9c4;
            transform: scale(1.01);
            transition: 0.2s;
        }

    @@media screen and (max-width: 768px) {

        .student-table,
        .student-table thead,
        .student-table tbody,
        .student-table th,
        .student-table td,
        .student-table tr {
            display: block;
            width: 100%;
        } 

            .student-table tr {
                margin-bottom: 15px;
                border-radius: 15px;
                overflow: hidden;
                box-shadow: 0 4px 10px rgba(0,0,0,0.1);
            }

            .student-table th {
                display: none;
            }

            .student-table td {
                text-align: left;
                padding-left: 50%;
                position: relative;
                background: white;
            }

            .student-table td::before {
                 position: absolute;
                 left: 15px;
                 top: 12px;
                 font-weight: bold;
                 color: #ff4081;
                }

                .student-table td:nth-child(1)::before {
                    content: "ID";
                }

                .student-table td:nth-child(2)::before {
                    content: "Name";
                }

                .student-table td:nth-child(3)::before {
                    content: "Role";
                }

                .student-table td:nth-child(4)::before {
                    content: "Subject";
                }

                .student-table td:nth-child(5)::before {
                    content: "Joined";
                }

                .student-table td:nth-child(6)::before {
                    content: "Actions";
                }
    }
</style>
<div class="form-container">
    <h2>Staff List</h2>
    <p>
        <a href="/Staff/Create/StafCreate" class="btn btn-success">
            + Add New Staff
        </a>
        <a href="/Dashboard/Index" class="btn btn-info">
            Back to Dashboard
        </a>
    </p>
    <table class="student-table">
        <tr>
            <th>ID</th>
            <th>Staff Name</th>
            <th>Role</th>
            <th>Subject</th>
            <th>Date Joined</th>
            <th>Actions</th>
        </tr>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.StaffId</td>
                <td>@item.StaffName</td>
                <td>@item.Role</td>
                <td>@item.Subject</td>
                <td>
                    @(item.DateJoined.HasValue
        ? item.DateJoined.Value.ToString("dd-MMM-yyyy")
        : "-")
                </td>

                <td>
                    <a href="/Staff/Edit/@item.StaffId"
                       class="btn btn-primary btn-sm">
                        Edit
                    </a>
                    <a href="/Staff/Delete/@item.StaffId"
                       class="btn btn-danger btn-sm"
                       onclick="return confirm('Are you sure?')">
                        Delete
                    </a>
                </td>
            </tr>
        }
    </table>
</div>