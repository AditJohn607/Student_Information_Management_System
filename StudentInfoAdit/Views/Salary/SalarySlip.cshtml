@model StudentInfoAdit.Models.SalaryPaymentModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Salary Slip</title>

    <style>
        body {
            font-family: Arial;
            padding: 30px;
        }

        .slip-container {
            width: 800px;
            margin: auto;
            border: 2px solid #333;
            padding: 25px;
        }

        .title {
            text-align: center;
            font-size: 28px;
            font-weight: bold;
            margin-bottom: 25px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        td {
            border: 1px solid #ddd;
            padding: 10px;
        }

        .print-btn {
            margin-top: 20px;
            padding: 10px 20px;
            background: green;
            color: white;
            border: none;
            cursor: pointer;
        }
    </style>
</head>

<body>

    <div class="slip-container">

        <div class="title">
            Salary Slip
        </div>

        <table>

            <tr>
                <td>Staff Name</td>
                <td>@Model.SalaryStructure.Staff.StaffName</td>
            </tr>

            <tr>
                <td>Month</td>
                <td>@Model.PaymentMonth</td>
            </tr>

            <tr>
                <td>Year</td>
                <td>@Model.PaymentYear</td>
            </tr>

            <tr>
                <td>Basic Salary</td>
                <td>@Model.SalaryStructure.BasicSalary</td>
            </tr>

            <tr>
                <td>HRA</td>
                <td>@Model.SalaryStructure.HRA</td>
            </tr>

            <tr>
                <td>DA</td>
                <td>@Model.SalaryStructure.DA</td>
            </tr>

            <tr>
                <td>Allowance</td>
                <td>@Model.SalaryStructure.OtherAllowance</td>
            </tr>

            <tr>
                <td><strong>Gross Salary</strong></td>
                <td><strong>@Model.GrossSalary</strong></td>
            </tr>

            <tr>
                <td>Paid Date</td>
                <td>@Model.PaidDate.ToString("dd-MM-yyyy")</td>
            </tr>

        </table>

        <button class="print-btn"
                onclick="window.print();">
            Print Salary Slip
        </button>

    </div>

</body>
</html>