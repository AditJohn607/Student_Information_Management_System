@model StudentInfoAdit.Models.AttendanceReportViewModel

@{
    ViewBag.Title = "Student Attendance Report";
}

<style>
    body {
        background-color: #f4f6f9;
        font-family: "Segoe UI", Arial, sans-serif;
    }

    .report-container {
        max-width: 1100px;
        margin: 30px auto;
    }

    .page-title {
        text-align: center;
        color: #224abe;
        font-size: 32px;
        font-weight: bold;
        margin-bottom: 25px;
    }

    .card {
        background: white;
        padding: 20px;
        margin-bottom: 20px;
        border-radius: 12px;
        box-shadow: 0 3px 10px rgba(0,0,0,0.15);
    }

        .card h3 {
            color: #224abe;
            margin-bottom: 15px;
        }

    .summary-grid {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 15px;
    }

    .summary-box {
        background: #f8f9fc;
        border-left: 5px solid #224abe;
        padding: 15px;
        border-radius: 8px;
        text-align: center;
    }

        .summary-box h2 {
            margin: 0;
            color: #224abe;
        }

    .attendance-table {
        width: 100%;
        border-collapse: collapse;
    }

        .attendance-table th {
            background: #224abe;
            color: white;
            padding: 10px;
            text-align: center;
        }

        .attendance-table td {
            padding: 10px;
            text-align: center;
            border-bottom: 1px solid #ddd;
        }

        .attendance-table tr:hover {
            background-color: #f1f5ff;
        }

    .present {
        color: green;
        font-weight: bold;
    }

    .absent {
        color: red;
        font-weight: bold;
    }

    .btn-back {
        display: inline-block;
        padding: 10px 18px;
        background: #224abe;
        color: white;
        text-decoration: none;
        border-radius: 8px;
        margin-top: 15px;
    }

        .btn-back:hover {
            background: #18338f;
            color: white;
            text-decoration: none;
        }

    .btn-print {
        display: inline-block;
        padding: 10px 18px;
        background: #28a745;
        color: white;
        text-decoration: none;
        border-radius: 8px;
        margin-top: 15px;
        margin-left: 10px;
    }

        .btn-print:hover {
            background: #218838;
            color: white;
            text-decoration: none;
        }

    @@media print {
        .btn-back,
        .btn-print {
            display: none;
        }
    }
</style>

<div class="report-container">

    <h2 class="page-title">
        Student Attendance Report
    </h2>

    <div class="card">

        <h3>Student Information</h3>

        <p>
            <b>Student ID :</b>
            @Model.Student.StudentId
        </p>

        <p>
            <b>Name :</b>
            @Model.Student.StudentName
        </p>

        <p>
            <b>Class :</b>
            @Model.Student.StudentClass
        </p>

    </div>

    <div class="card">

        <h3>Attendance Summary</h3>

        <div class="summary-grid">

            <div class="summary-box">
                <h2>@Model.TotalDays</h2>
                <p>Total Records</p>
            </div>

            <div class="summary-box">
                <h2>@Model.PresentDays</h2>
                <p>Present Days</p>
            </div>

            <div class="summary-box">
                <h2>
                    @Model.AttendancePercentage.ToString("0.00")%
                </h2>
                <p>Attendance Percentage</p>
            </div>

        </div>

    </div>

    <div class="card">

        <h3>Attendance History</h3>

        @if (Model.AttendanceRecords != null &&
             Model.AttendanceRecords.Count > 0)
        {
            <table class="attendance-table">

                <tr>
                    <th>Date</th>
                    <th>In Time</th>
                    <th>Out Time</th>
                    <th>Status</th>
                </tr>

                @foreach (var item in Model.AttendanceRecords)
                {
                    <tr>

                        <td>
                            @item.AttendanceDate.ToString("dd-MM-yyyy")
                        </td>

                        <td>
                            @(item.InTime.HasValue
                                ? item.InTime.Value.ToString(@"hh\:mm")
                                : "-")
                        </td>

                        <td>
                            @(item.OutTime.HasValue
                                ? item.OutTime.Value.ToString(@"hh\:mm")
                                : "-")
                        </td>

                        <td>

                            @if (item.IsPresent)
                            {
                                <span class="present">
                                    Present
                                </span>
                            }
                            else
                            {
                                <span class="absent">
                                    Absent
                                </span>
                            }

                        </td>

                    </tr>
                }

            </table>
        }
        else
        {
            <p>No attendance records found.</p>
        }

    </div>

    <a href="@Url.Action("Details","Attendance")"
       class="btn-back">
        ← Back
    </a>

    <a href="#"
       onclick="window.print();"
       class="btn-print">
        Print Report
    </a>

</div>