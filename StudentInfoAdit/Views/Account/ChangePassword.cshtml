@{
    ViewBag.Title = "Change Password";
}

<style>
    body {
        margin: 0;
        font-family: "Segoe UI", Arial, sans-serif;
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #43a047, #cddc39);
    }

    .password-wrapper {
        width: 450px;
        background: #fff;
        padding: 40px;
        border-radius: 15px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.3);
    }

        .password-wrapper h2 {
            text-align: center;
            color: #43a047;
            margin-bottom: 25px;
            font-size: 28px;
            font-weight: 700;
        }

    .form-group {
        margin-bottom: 18px;
    }

    label {
        display: block;
        margin-bottom: 5px;
        font-weight: 600;
        color: #444;
    }

    input[type="password"] {
        width: 100%;
        padding: 12px;
        border: 1px solid #ddd;
        border-radius: 8px;
        outline: none;
        box-sizing: border-box;
        transition: 0.2s;
    }

    input:focus {
        border-color: #cddc39;
        box-shadow: 0 0 6px rgba(205,220,57,0.4);
    }

    .btn-save {
        width: 100%;
        padding: 12px;
        background: linear-gradient(135deg, #43a047, #cddc39);
        border: none;
        color: white;
        font-size: 16px;
        font-weight: 600;
        border-radius: 8px;
        cursor: pointer;
        margin-top: 10px;
        transition: 0.3s;
    }

        .btn-save:hover {
            transform: scale(1.03);
            box-shadow: 0 8px 20px rgba(0,0,0,0.2);
        }

    .message {
        color: green;
        text-align: center;
        margin-bottom: 15px;
        font-weight: bold;
    }

    .error {
        color: red;
        text-align: center;
        margin-bottom: 15px;
        font-weight: bold;
    }

    .back-link {
        margin-top: 20px;
        text-align: center;
    }

        .back-link a {
            color: #43a047;
            text-decoration: none;
            font-weight: 600;
        }

            .back-link a:hover {
                text-decoration: underline;
            }
</style>

<div class="password-container">

    <h2>Change Password</h2>

    @if (ViewBag.Message != null)
    {
        <div class="message">@ViewBag.Message</div>
    }

    @if (ViewBag.Error != null)
    {
        <div class="error">@ViewBag.Error</div>
    }  

    @using (Html.BeginForm("ChangePassword", "Account", FormMethod.Post))
    {
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label>Current Password</label>
            <input type="password" name="currentPassword" required />
        </div>

        <div class="form-group">
            <label>New Password</label>
            <input type="password" name="newPassword" required />
        </div>

        <div class="form-group">
            <label>Confirm New Password</label>
            <input type="password" name="confirmPassword" required />
        </div>

        <input type="submit" value="Update Password" class="btn-save" />
    }

</div>
