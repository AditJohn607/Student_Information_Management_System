@{
    ViewBag.Title = "Teacher Dashboard";
}

<link href="~/Content/dashboard.css" rel="stylesheet" />

<div style="position:absolute; bottom:15px; left:20px;">
    <a href="@Url.Action("ChangePassword", "Account")"
       style="padding:10px 15px;
          background:#007cba;
          color:white;
          text-decoration:none;
          border-radius:6px;">
        Change Password
    </a>
</div>

    <div style="position:absolute; top:15px; left:20px;">
        <a href="@Url.Action("Logout", "Account")"
           style="padding: 10px 15px; background: #ff7500; color: white; text-decoration: none; border-radius: 6px;">
            Logout
        </a>
    </div>

    <div class="dashboard-container">
        <h1>Teacher Dashboard</h1>
        <div class="row">
            <div class="col-md-4">
                <div class="panel">
                    <div class="panel-heading">Students</div>
                    <div class="panel-body">
                        <h2>@ViewBag.TotalStudents</h2>
                        <p>Total Students Assigned</p>
                        <a href="@Url.Action("StudentDetails", "Student")" class="dashboard-btn">VIEW</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="panel">
                    <div class="panel-heading">Attendance</div>
                    <div class="panel-body">
                        <h2>@ViewBag.TodayAttendance</h2>
                        <p>Attendance Records</p>
                        <a href="@Url.Action("AttendanceDetails", "Attendance")" class="dashboard-btn">MARK / VIEW</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="panel">
                    <div class="panel-heading">Exams</div>
                    <div class="panel-body">
                        <h2>Exam</h2>
                        <p>Manage Marks & Results</p>
                        <a href="@Url.Action("Index", "Exam")" class="dashboard-btn">OPEN</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="panel">
                    <div class="panel-heading">Assignment</div>
                    <div class="panel-body">
                        <h2>Exam</h2>
                        <p>Manage Assignments</p>
                        <a href="@Url.Action("Index", "Assignment")" class="dashboard-btn">OPEN</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="panel">
                    <div class="panel-heading">Notices</div>
                    <div class="panel-body">
                        <h2>Exam</h2>
                        <p>Click to view recent notices</p>
                        <a href="@Url.Action("Index", "Notice")" class="dashboard-btn">OPEN</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="panel">
                    <div class="panel-heading">Time Table</div>
                    <div class="panel-body">
                        <p>To view Time Table</p>
                        <a href="@Url.Action("Index", "Timetable")" class="dashboard-btn">OPEN</a>
                    </div>
                </div>
            </div>
        </div>
    </div>