@{
    ViewBag.Title = "Accountant Dashboard";
}

<link href="~/Content/dashboard.css" rel="stylesheet" />

<div style="position:absolute; top:15px; right:20px;">
    <a href="@Url.Action("ChangePassword", "Account")"
       style="padding: 10px 15px; background: #ff5e00; color: white; text-decoration: none; border-radius: 6px;">
        Change Password
    </a>
</div>

<div class="dashboard-container">

    <h1>Accountant Dashboard</h1>

    <div style="position:absolute; top:15px; left:20px;">
        <a href="@Url.Action("Logout", "Account")"
           style="padding: 10px 15px; background: #ff7500; color: white; text-decoration: none; border-radius: 6px;">
            Logout
        </a>
    </div>

    <div class="row">

        <div class="col-md-4">
            <div class="panel">
                <div class="panel-heading">Total Fees Collected</div>
                <div class="panel-body">
                    <h2>₹ @ViewBag.TotalFees</h2>
                    <p>Overall Collection</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="panel">
                <div class="panel-heading">Pending Fees</div>
                <div class="panel-body">
                    <h2>₹ @ViewBag.PendingFees</h2>
                    <p>Outstanding Amount</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="panel">
                <div class="panel-heading">Pending Fees</div>
                <div class="panel-body">
                    <h2> @ViewBag.PendingFees</h2>
                    <p>Outstanding Amount</p>
                </div>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="panel">
                <div class="panel-heading">Fee Structure</div>
                <div class="panel-body">
                    <h2>Info</h2>
                    <p>Class-wise Fee Setup</p>
                    <a href="@Url.Action("Index", "Fee")" class="dashboard-btn">VIEW</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="panel">
                <div class="panel-heading">Student Fees</div>
                <div class="panel-body">
                    <h2>@ViewBag.TotalStudents</h2>
                    <p>Fee Records by Student</p>
                    <a href="@Url.Action("StudentDetails", "Student")" class="dashboard-btn">VIEW</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="panel">
                <div class="panel-heading">Salary Module</div>
                <div class="panel-body">
                    <p>Manage Salary of Employees</p>
                    <a href="@Url.Action("Index", "Salary")" class="dashboard-btn">VIEW</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="panel">
                <div class="panel-heading">Notices</div>
                <div class="panel-body">
                    <h2>@ViewBag.TotalStudents</h2>
                    <p>Click here to view recent notices</p>
                    <a href="@Url.Action("Index", "Notice")" class="dashboard-btn">VIEW</a>
                </div>
            </div>
        </div>

    </div>

</div>