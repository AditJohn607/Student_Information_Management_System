@{
    ViewBag.Title = "Admin Dashboard";
}

<style>
    :root {
        --primary: #43a047;
        --primary-dark: #2e7d32;
        --accent: #cddc39;
        --text-light: #fff;
        --bg: #f4f7f4;
        --card-bg: #ffffff;
        --border: #e0e6e0;
        --shadow: 0 10px 25px rgba(0,0,0,0.10);
        --radius: 12px;
    }

    body {
        margin: 0;
        background: var(--bg);
        font-family: "Segoe UI", Arial, sans-serif;
    }

    .dashboard-container {
        max-width: 1100px;
        margin: 50px auto;
        padding: 20px;
    }

    h1 {
        text-align: center;
        font-size: 36px;
        font-weight: 800;
        margin-bottom: 35px;
        color: var(--primary);
        text-transform: uppercase;
    }

    .row {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
    }

    .col-md-3 {
        flex: 0 0 calc(25% - 20px);
    }

    .panel {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        transition: 0.3s;
        text-align: center;
        overflow: hidden;
    }

        .panel:hover {
            transform: translateY(-6px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.15);
            border-color: var(--primary);
        }

    .panel-heading {
        background: linear-gradient(135deg, var(--primary), var(--accent));
        color: var(--text-light);
        padding: 14px;
        font-size: 14px;
        font-weight: 700;
        letter-spacing: 0.5px;
    }

    .panel-body {
        padding: 25px;
        background: #fff;
    }

        .panel-body h2 {
            font-size: 34px;
            color: var(--primary);
            margin: 0;
        }

        .panel-body p {
            margin-top: 10px;
            color: #666;
            font-weight: 600;
        }

    @@media (max-width: 992px) {
        .col-md-3 {
            flex: 0 0 calc(50% - 20px);
        }
    }
    
    @@media (max-width: 600px) {
        .col-md-3 {
            flex: 0 0 100%;
        }

        h1 {
            font-size: 26px;
        }
    }
</style>

<div style="position:absolute; bottom:15px; left:20px;">
    <a href="@Url.Action("ChangePassword", "Account")"
       style="padding:10px 15px;
          background:#007cba;
          color:white;
          text-decoration:none;
          border-radius:6px;">
        Change Password
    </a>
</div>

<div style="position:absolute; top:15px; left:20px;">
    <a href="@Url.Action("Logout", "Account")"
       style="padding:10px 15px;
              background:#dc3545;
              color:white;
              text-decoration:none;
              border-radius:6px;">
        Logout
    </a>
</div>

<div style="position:absolute; top:15px; right:20px;">
    <a href="@Url.Action("ERP","Dashboard")"
       style="padding:10px 15px; background:#28a745; color:white; text-decoration:none; border-radius:6px;">
        Enter ERP
    </a>
</div>

<div class="dashboard-container">

    <h1>Admin Dashboard</h1>
    <div class="row">

        <div class="col-md-3">
            <div class="panel">
                <div class="panel-heading">Total Students</div>
                <div class="panel-body">
                    <h2>@ViewBag.TotalStudents</h2>
                    <p>Registered Students</p>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="panel">
                <div class="panel-heading">Total Staff</div>
                <div class="panel-body">
                    <h2>@ViewBag.TotalStaff</h2>
                    <p>Teaching & Non-Teaching</p>
                </div>
            </div>
        </div>
        
        <div class="col-md-3">
            <div class="panel">
                <div class="panel-heading">Fees Collected</div>
                <div class="panel-body">
                    <h2>₹ @ViewBag.TotalFees</h2>
                    <p>Total Revenue</p>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="panel">
                <div class="panel-heading">Notices</div>
                <div class="panel-body">
                    <h2>@ViewBag.TotalNotices</h2>
                    <p>Active Announcements</p>
                </div>
            </div>
        </div>
    </div>
</div>