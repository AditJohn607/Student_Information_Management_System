@model StudentInfoAdit.Models.FeeStructure

@{
    ViewBag.Title = "Create Fee Structure";
}

<style>
    body {
        font-family: "Segoe UI", Arial;
        background: #f4f6f9;
    }

    .container-box {
        max-width: 700px;
        margin: 50px auto;
    }

    .title {
        text-align: center;
        font-size: 30px;
        font-weight: bold;
        color: #224abe;
        margin-bottom: 25px;
    }

    .card {
        background: white;
        padding: 25px;
        border-radius: 12px;
        box-shadow: 0 3px 12px rgba(0,0,0,0.1);
    }

    .form-group {
        margin-bottom: 15px;
    }

    label {
        font-weight: bold;
        display: block;
        margin-bottom: 5px;
    }

    .form-control {
        width: 100%;
        padding: 10px;
        border-radius: 8px;
        border: 1px solid #ddd;
    }

    .btn {
        background: #28a745;
        color: white;
        padding: 10px 18px;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        width: 100%;
        font-size: 16px;
    }

        .btn:hover {
            background: #218838;
        }

    .back {
        display: block;
        text-align: center;
        margin-top: 15px;
        text-decoration: none;
        color: #224abe;
    }
</style>

<div class="container-box">

    <div class="title">➕ Create Fee Structure</div>

    <div class="card">

        @using (Html.BeginForm("Create", "Fee", FormMethod.Post))
        {
            <!-- STUDENT ID -->
            <div class="form-group">
                <label>Student</label>
                @Html.DropDownList("StudentId",
                    ViewBag.Students as SelectList,
                    "-- Select Student --",
                    new { @class = "form-control" })
            </div>

            <!-- ACADEMIC YEAR -->
            <div class="form-group">
                <label>Academic Year</label>
                <input type="text"
                       name="AcademicYear"
                       class="form-control"
                       placeholder="e.g. 2025-2026"
                       required />
            </div>

            <div class="form-group">
                <label>Total Fee</label>
                <input type="number"
                       name="TotalFee"
                       class="form-control"
                       required />
            </div>
            <button type="submit" class="btn">
                Create Fee Structure
            </button>
        }
        <a href="@Url.Action("Index","Fee")" class="back">
            ← Back to Fee Module
        </a>
    </div>
</div>