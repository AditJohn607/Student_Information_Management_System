@model StudentInfoAdit.Models.FeeViewModel

@{
    ViewBag.Title = "Add Payment";
}

<style>
    body {
        font-family: "Segoe UI", Arial;
        background: #f4f6f9;
    }

    .container-box {
        max-width: 700px;
        margin: 50px auto;
    }

    .title {
        text-align: center;
        font-size: 28px;
        font-weight: bold;
        color: #224abe;
        margin-bottom: 20px;
    }

    .card {
        background: white;
        padding: 25px;
        border-radius: 12px;
        box-shadow: 0 3px 12px rgba(0,0,0,0.1);
    }

    .info {
        background: #f8f9fa;
        padding: 15px;
        border-radius: 8px;
        margin-bottom: 15px;
    }

    label {
        font-weight: bold;
        display: block;
        margin-top: 10px;
    }

    .form-control {
        width: 100%;
        padding: 10px;
        border-radius: 8px;
        border: 1px solid #ddd;
        margin-top: 5px;
    }

    .btn {
        background: #28a745;
        color: white;
        padding: 10px 18px;
        border: none;
        border-radius: 8px;
        margin-top: 15px;
        width: 100%;
        font-size: 16px;
        cursor: pointer;
    }

        .btn:hover {
            background: #218838;
        }

    .back {
        display: block;
        text-align: center;
        margin-top: 15px;
        color: #224abe;
        text-decoration: none;
    }

    .row {
        display: flex;
        justify-content: space-between;
    }
</style>

<div class="container-box">

    <div class="title"> Add Payment </div>

    <div class="card">

        <div class="info">
            <p><b>Student:</b> @Model.Student.StudentName</p>
            <p><b>Class:</b> @Model.Student.StudentClass</p>
        </div>

        <div class="info">
            <p><b>Total Fee:</b> @Model.Fee.TotalFee</p>
            <p><b>Paid:</b> @Model.TotalPaid</p>
            <p><b>Balance:</b> @Model.Balance</p>
        </div>
        
        @using (Html.BeginForm("AddPayment", "Fee", FormMethod.Post))
        {
            @Html.Hidden("feeId", Model.Fee.FeeId)

            <label>Amount</label>
            <input type="number"
                   name="amountPaid"
                   class="form-control"
                   required />

            <label>Payment Mode</label>
            <select name="paymentMode" class="form-control">
                <option>Cash</option>
                <option>UPI</option>
                <option>Card</option>
                <option>Net Banking</option>
            </select>

            <button type="submit" class="btn">
                Submit Payment
            </button>
        }

        <a href="@Url.Action("Details","Fee", new { studentId = Model.Student.StudentId })"
           class="back">
            ← Back to Details
        </a>
    </div>
</div>