 @model StudentInfoAdit.Models.IssueBookViewModel

@{
    ViewBag.Title = "Issue Book";
}

<style>
    body {
        font-family: "Segoe UI", Arial;
        background: #f4f6f9;
        margin: 0;
        padding: 0;
    }

    .form-container {
        width: 500px;
        margin: 50px auto;
        background: #fff;
        padding: 25px;
        border-radius: 10px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.1);
    }

    h2 {
        text-align: center;
        color: #2e7d32;
        margin-bottom: 20px;
    }

    .form-group {
        margin-bottom: 15px;
    }

    label {
        font-weight: 600;
        display: block;
        margin-top: 10px;
        margin-bottom: 5px;
    }

    input,
    select,
    textarea {
        width: 100%;
        padding: 10px;
        border: 1px solid #ccc;
        border-radius: 6px;
        outline: none;
        box-sizing: border-box;
    }

        input:focus,
        select:focus,
        textarea:focus {
            border-color: #43a047;
            box-shadow: 0 0 5px rgba(67,160,71,0.3);
        }

    .btn-primary {
        width: 100%;
        margin-top: 20px;
        padding: 12px;
        background: linear-gradient(135deg, #43a047, #cddc39);
        border: none;
        color: white;
        font-size: 16px;
        font-weight: bold;
        border-radius: 6px;
        cursor: pointer;
        transition: 0.3s;
    }

        .btn-primary:hover {
            transform: scale(1.03);
        }

    .alert-success {
        background: #d4edda;
        color: #155724;
        padding: 12px;
        border-radius: 6px;
        margin-bottom: 15px;
        border: 1px solid #43a047;
    }

    .text-danger {
        color: #dc3545;
        font-weight: bold;
        margin-top: 10px;
    }

    @@media screen and (max-width: 600px) {
        .form-container {
            width: 90%;
            padding: 20px;
        }

        h2 {
            font-size: 22px;
        }
    }
</style>

<div class="form-container">

    <h2>📚 Issue Book</h2>

    @if (TempData["Success"] != null)
    {
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
    }

    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

    @using (Html.BeginForm())
    {
    @Html.AntiForgeryToken()

    <div class="form-group">
        <label> Student</label>

        @Html.DropDownListFor(
                m => m.StudentId,
                Model.StudentList,
                "-- Select Student --",
                new
                {
                    @class = "form-control",
                    id = "StudentId"
                })
    </div>

    <div class="form-group">
        <label>📖 Book</label>

        @Html.DropDownListFor(
                m => m.BookId,
                Model.BookList,
                "-- Select Book --",
                new { @class = "form-control" })
    </div>

    <div class="form-group">
        <label>📅 Due Date</label>

        @Html.TextBoxFor(
                m => m.DueDate,
                "{0:yyyy-MM-dd}",
                new
                {
                    @class = "form-control",
                    type = "date"
                })
    </div>

    <button type="submit" class="btn btn-primary">
        📚 Issue Book
    </button>
    }
</div>

@section Scripts{
    <script>
        $(document).ready(function () {
            $("#studentSearch").keyup(function () {
                var value = $(this).val().toLowerCase();

                $("#StudentId option").each(function () {

                    if ($(this).val() == "")
                        return;
     
                    $(this).toggle(
                        $(this).text().toLowerCase().indexOf(value) > -1
                    );
                });
            });
        });
    </script>
}