@model IEnumerable<StudentInfoAdit.Models.BookIssuedModel>

@{
    ViewBag.Title = "Issued Books";
}

<style>
    body {
        margin: 0;
        padding: 0;
        font-family: 'Comic Sans MS', 'Segoe UI', sans-serif;
        background: linear-gradient(135deg, #a8edea, #fed6e3);
        min-height: 100vh;
    }

    .table-container {
        width: 90%;
        max-width: 1100px;
        margin: 50px auto;
        background: #ffffff;
        padding: 30px;
        border-radius: 25px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.15);
        border: 5px dashed #ffb6c1;
    }

    h2 {
        text-align: center;
        color: #ff4f81;
        font-size: 32px;
        margin-bottom: 25px;
        text-shadow: 2px 2px #ffe066;
    }

    .alert-success {
        background: #d4edda;
        color: #155724;
        padding: 12px;
        border-radius: 10px;
        margin-bottom: 20px;
        border: 2px solid #4caf50;
        font-weight: bold;
    }

    .table {
        width: 100%;
        border-collapse: collapse;
        overflow: hidden;
        border-radius: 15px;
    }

        .table thead {
            background: #ff69b4;
            color: white;
        }

        .table th {
            padding: 15px;
            text-align: center;
            font-size: 18px;
        }

        .table td {
            padding: 14px;
            text-align: center;
            font-size: 16px;
            color: #444;
            border-bottom: 1px solid #f0f0f0;
        }

        .table tbody tr:nth-child(even) {
            background: #fff7fb;
        }

        .table tbody tr:nth-child(odd) {
            background: #f0fbff;
        }

        .table tbody tr:hover {
            background: #fff3cd;
            transform: scale(1.01);
            transition: 0.3s;
        }

    .status-issued {
        color: #ff7043;
        font-weight: bold;
    }

    .status-returned {
        color: #4caf50;
        font-weight: bold;
    }

    .btn {
        padding: 10px 18px;
        border: none;
        border-radius: 12px;
        text-decoration: none;
        font-size: 15px;
        font-weight: bold;
        transition: 0.3s;
        display: inline-block;
    }

    .btn-success {
        background: #4caf50;
        color: white;
    }

        .btn-success:hover {
            background: #43a047;
            transform: scale(1.05);
        }

    .btn-primary {
        background: #2196f3;
        color: white;
        margin-top: 20px;
    }

        .btn-primary:hover {
            background: #1976d2;
            transform: scale(1.05);
        }

    .button-container {
        text-align: center;
        margin-top: 25px;
    }

    @@media screen and (max-width: 768px) {

        .table-container {
            width: 95%;
            padding: 15px;
        }

        h2 {
            font-size: 26px;
        }

        .table {
            display: block;
            overflow-x: auto;
            white-space: nowrap;
        }

        .btn {
            width: 100%;
            margin-top: 5px;
        }
    }
</style>
<div class="table-container">
    <h2> Issued Books </h2>
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
             @TempData["Success"]
        </div>
    }
    <table class="table">
        <thead>
            <tr>
                <th> Student</th>
                <th> Book</th>
                <th> Issue Date</th>
                <th> Due Date</th>
                <th> Status</th>
                <th> Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Student.StudentName</td>
                    <td>@item.Book.BookName</td>
                    <td>@item.IssueDate.ToString("dd-MMM-yyyy")</td>
                    <td>@item.DueDate.ToString("dd-MMM-yyyy")</td>
                    <td>
                        @if (item.Returned)
                        {
                            <span class="status-returned">Returned</span>
                        }
                        else
                        {
                            <span class="status-issued">Issued</span>
                        }
                    </td>
                    <td>
                        @if (!item.Returned)
                        {
                            @Html.ActionLink(
                                "↩ Return",
                                "ReturnBook",
                                new { id = item.IssueId },
                                new { @class = "btn btn-success" }
                            )
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <div class="button-container">
        @Html.ActionLink(
            "Issue New Book",
            "IssueBook",
            null,
            new { @class = "btn btn-primary" }
        )
    </div>
</div>