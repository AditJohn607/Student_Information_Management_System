@model IEnumerable<StudentInfoAdit.Models.BookIssuedModel>

@{
    ViewBag.Title = "Issued Books";
}

<style>
    body {
        font-family: "Segoe UI", Arial;
        background: #f4f6f9;
        margin: 0;
        padding: 0;
    }

    .table-container {
        width: 90%;
        max-width: 1100px;
        margin: 50px auto;
        background: #fff;
        padding: 25px;
        border-radius: 10px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.1);
    }

    h2 {
        text-align: center;
        color: #2e7d32;
        margin-bottom: 20px;
    }

    .alert-success {
        background: #d4edda;
        color: #155724;
        padding: 12px;
        border-radius: 6px;
        margin-bottom: 15px;
        border: 1px solid #43a047;
        font-weight: bold;
    }

    .table {
        width: 100%;
        border-collapse: collapse;
        border-radius: 8px;
        overflow: hidden;
    }

        .table thead {
            background: linear-gradient(135deg, #43a047, #cddc39);
            color: black;
        }

        .table th {
            padding: 14px;
            text-align: center;
            font-size: 16px;
        }

        .table td {
            padding: 12px;
            text-align: center;
            border-bottom: 1px solid #eee;
            color: #333;
        }

        .table tbody tr:nth-child(even) {
            background: #f9f9f9;
        }

        .table tbody tr:nth-child(odd) {
            background: #ffffff;
        }

        .table tbody tr:hover {
            background: #f2f6ff;
            transition: 0.2s;
        }

    .status-issued {
        color: #ff7043;
        font-weight: bold;
    }

    .status-returned {
        color: #43a047;
        font-weight: bold;
    }

    .btn {
        padding: 8px 14px;
        border: none;
        border-radius: 6px;
        text-decoration: none;
        font-size: 14px;
        font-weight: bold;
        transition: 0.3s;
        display: inline-block;
        cursor: pointer;
    }

    .btn-success {
        background: #43a047;
        color: white;
    }

        .btn-success:hover {
            background: #2e7d32;
        }

    .btn-primary {
        background: #007cba;
        color: white;
    }

        .btn-primary:hover {
            background: #005f8a;
        }

    .button-container {
        text-align: center;
        margin-top: 20px;
    }

    @@media screen and (max-width: 768px) {

        .table-container {
            width: 95%;
            padding: 15px;
        }

        h2 {
            font-size: 22px;
        }

        .table {
            display: block;
            overflow-x: auto;
            white-space: nowrap;
        }

        .btn {
            width: 100%;
            margin-top: 5px;
        }
    }
</style>

<div class="table-container">
    <h2> Issued Books </h2>
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
             @TempData["Success"]
        </div>
    }

    <table class="table">
        <thead>
            <tr>
                <th> Student</th>
                <th> Book</th>
                <th> Issue Date</th>
                <th> Due Date</th>
                <th> Status</th>
                <th> Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Student.StudentName</td>
                    <td>@item.Book.BookName</td>
                    <td>@item.IssueDate.ToString("dd-MMM-yyyy")</td>
                    <td>@item.DueDate.ToString("dd-MMM-yyyy")</td>
                    <td>
                        @if (item.Returned)
                        {
                            <span class="status-returned">Returned</span>
                        }
                        else
                        {
                            <span class="status-issued">Issued</span>
                        }
                    </td>
                    <td>
                        @if (!item.Returned)
                        {
                            @Html.ActionLink(
                                "↩ Return",
                                "ReturnBook",
                                new { id = item.IssueId },
                                new { @class = "btn btn-success" }
                            )
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <div class="button-container">
        @Html.ActionLink(
            "Issue New Book",
            "IssueBook",
            null,
            new { @class = "btn btn-primary" }
        )
    </div>
</div>