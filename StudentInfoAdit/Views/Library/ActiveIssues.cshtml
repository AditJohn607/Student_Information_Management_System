@model IEnumerable<StudentInfoAdit.Models.BookIssuedModel>
@{
    ViewBag.Title = "Active Issues";
}
<style>
    body {
        margin: 0;
        padding: 0;
        font-family: 'Comic Sans MS', 'Segoe UI', sans-serif;
        background: linear-gradient(135deg, #a8edea, #fed6e3);
        min-height: 100vh;
    }
    .table-container {
        width: 90%;
        max-width: 1100px;
        margin: 50px auto;
        background: #ffffff;
        padding: 30px;
        border-radius: 25px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.15);
        border: 5px dashed #ffb6c1;
    }
    h2 {
        text-align: center;
        color: #ff4f81;
        font-size: 32px;
        margin-bottom: 25px;
        text-shadow: 2px 2px #ffe066;
    }
    .table {
        width: 100%;
        border-collapse: collapse;
        border-radius: 15px;
        overflow: hidden;
    }
        .table thead {
            background: #ff69b4;
            color: white;
        }
        .table th {
            padding: 15px;
            text-align: center;
            font-size: 18px;
        }
        .table td {
            padding: 14px;
            text-align: center;
            font-size: 16px;
            color: #444;
            border-bottom: 1px solid #f0f0f0;
        }
        .table tbody tr:nth-child(odd) {
            background: #f0fbff;
        }

        .table tbody tr:nth-child(even) {
            background: #fff7fb;
        }

        .table tbody tr:hover {
            background: #fff3cd;
            transition: 0.3s;
            transform: scale(1.01);
        }

    .btn {
        padding: 10px 18px;
        border: none;
        border-radius: 12px;
        text-decoration: none;
        font-size: 15px;
        font-weight: bold;
        transition: 0.3s;
        display: inline-block;
    }

    .btn-success {
        background: #4caf50;
        color: white;
    }

        .btn-success:hover {
            background: #43a047;
            transform: scale(1.05);
        }

    @@media screen and (max-width: 768px) {

        .table-container {
            width: 95%;
            padding: 15px;
        }

        h2 {
            font-size: 26px;
        }

        .table {
            display: block;
            overflow-x: auto;
            white-space: nowrap;
        }

        .btn {
            width: 100%;
        }
    }
</style>

<div class="table-container">

    <h2> Currently Issued Books</h2>

    <table class="table table-bordered table-hover">
        <thead>
            <tr>
                <th> Student</th>
                <th> Book</th>
                <th> Issue Date</th>
                <th> Due Date</th>
                <th> Return</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Student.StudentName</td>
                    <td>@item.Book.BookName</td>
                    <td>@item.IssueDate.ToString("dd-MMM-yyyy")</td>
                    <td>@item.DueDate.ToString("dd-MMM-yyyy")</td>
                    <td>
                        @Html.ActionLink(
                            "↩ Return Book",
                            "ReturnBook",
                            new { id = item.IssueId },
                            new { @class = "btn btn-success" })
                    </td>
                </tr>
            }
        </tbody>
   </table>
</div>